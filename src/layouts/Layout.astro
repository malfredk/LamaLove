---
import "../styles/global.css";

interface Props {
  title?: string;
  activePage?: "home" | "information";
}

const { title = "L&M", activePage = "home" } = Astro.props;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&family=Pinyon+Script&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg" href="/rings.svg" />
  </head>

  <body>
    <main class="page">
      <header class="top-header">
        <h1 class="names">Lars &amp; Malene</h1>

        <div class="nav-row">
          <div class="line"></div>

          <div class="nav-center">
            <nav class="nav">
              <a href="/" class={activePage === "home" ? "active" : ""}>hjem</a>
              <a
                href="https://docs.google.com/forms/d/e/1FAIpQLSf4KKQrjfa4TAMqrxjPYayEuRd9ZH6r2JAWrv56IEIv5px8AA/viewform?usp=header"
                target="_blank"
                rel="noopener noreferrer"
              >
                svar på invitasjon
              </a>
              <a
                href="/information"
                class={activePage === "information" ? "active" : ""}
              >
                informasjon
              </a>
            </nav>

            <p class="nav-deadline">frist 1. juli</p>
          </div>

          <div class="line"></div>
        </div>
      </header>

      <slot />
    </main>
  </body>
</html>
